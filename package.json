{
  "name": "discord-poker-bot",
  "version": "1.0.0",
  "description": "Discord Texas Hold'em Poker Bot with Vue.js frontend",
  "type": "module",
  "scripts": {
    "start": "node start.js",
    "deploy-commands": "node bot/deploy-commands.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  }
}
